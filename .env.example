# Database
DATABASE_URL=sqlite:///./data/kbo_auth.db

# JWT Auth
JWT_SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=https://kbo-prediction-lilac.vercel.app,http://localhost:3000

# Email verification (Resend)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=KBO AI Analyzer <noreply@kbo-analyzer.com>

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_BASIC_PRICE_ID=price_xxxxx
STRIPE_PRO_PRICE_ID=price_xxxxx

# Anthropic API (LLM 에이전트용)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API (Analyst, Synthesizer 에이전트)
GOOGLE_API_KEY=your_google_api_key

# Redis (옵션 — 없으면 파일 캐시 사용)
REDIS_URL=redis://localhost:6379

# Kaggle API (데이터 다운로드용)
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_key
